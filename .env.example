# =============================================================================
# ChurnGuard — Environment Variables
# Copy this file to .env.local for local development.
# ALL variables marked [REQUIRED] must be set. Others are optional.
# =============================================================================

# ─── Aurora DSQL ─────────────────────────────────────────────────────────────
# [REQUIRED] PostgreSQL connection string to your Aurora DSQL cluster.
# Get from: AWS Console → Amazon Aurora → DSQL → your cluster → Endpoint
# Format:   postgresql://admin:<password>@<cluster-id>.dsql.eu-central-1.on.aws:5432/postgres?sslmode=require
DATABASE_URL="postgresql://admin:YOUR_DSQL_PASSWORD@YOUR_CLUSTER_ID.dsql.eu-central-1.on.aws:5432/postgres?sslmode=require"

# [REQUIRED] Cluster endpoint hostname only (used for SDK token auth in production)
# Same value as the host part of DATABASE_URL above
DSQL_CLUSTER_ENDPOINT="YOUR_CLUSTER_ID.dsql.eu-central-1.on.aws"

# [REQUIRED] AWS region where your Aurora DSQL cluster lives
AWS_REGION="eu-central-1"

# ─── AWS Credentials (for Bedrock + DSQL from Vercel) ────────────────────────
# [REQUIRED] IAM user credentials that have:
#   - bedrock:InvokeModel on eu.anthropic.claude-3-haiku-20240307-v1:0
#   - secretsmanager:GetSecretValue on your DSQL secret
# Create at: AWS Console → IAM → Users → Create user → Attach policies
# NEVER commit real credentials — Vercel env vars are encrypted at rest
AWS_ACCESS_KEY_ID="AKIAIOSFODNN7EXAMPLE"
AWS_SECRET_ACCESS_KEY="wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY"

# ─── Amazon Bedrock ───────────────────────────────────────────────────────────
# [INFORMATIONAL] These are not env vars — they are hard-coded in src/app/api/insights/route.ts
# Model used: eu.anthropic.claude-3-haiku-20240307-v1:0 (cross-region inference, eu-central-1)
# Before using: enable model access at AWS Console → Bedrock → Model access → Request access
# BEDROCK_MODEL_ID is set in code; change it there if you want a different model.

# ─── NextAuth.js ─────────────────────────────────────────────────────────────
# [REQUIRED] Full URL of your app (no trailing slash)
# Local:      http://localhost:3000
# Production: https://your-app.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# [REQUIRED] Random secret for signing session cookies.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Or online:     https://generate-secret.vercel.app/32
NEXTAUTH_SECRET="REPLACE_WITH_32_CHAR_RANDOM_HEX_STRING"

# ─── Google OAuth ────────────────────────────────────────────────────────────
# [REQUIRED] Google OAuth 2.0 credentials.
# Setup steps: see SETUP.md → "Google OAuth Setup"
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID="your-google-client-id-from-gcp-console"
GOOGLE_CLIENT_SECRET="your-google-client-secret-from-gcp-console"

# ─── Stripe (optional — for MRR tracking) ───────────────────────────────────
# [OPTIONAL] Stripe keys for subscription billing integration.
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="your-stripe-secret-key"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="your-stripe-publishable-key"
STRIPE_WEBHOOK_SECRET="your-stripe-webhook-secret"

# ─── Resend (optional — for email alerts) ───────────────────────────────────
# [OPTIONAL] Resend API key for sending churn alert emails to CS teams.
# Get from: https://resend.com/api-keys
RESEND_API_KEY="your-resend-api-key"
EMAIL_FROM="alerts@yourdomain.com"

# ─── Slack (optional — for CS team notifications) ───────────────────────────
# [OPTIONAL] Slack incoming webhook URL for high-risk customer alerts.
# Create at: https://api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_URL="your-slack-webhook-url"

# ─── ChurnGuard SDK secret ───────────────────────────────────────────────────
# [REQUIRED] Secret key tenants use in the Authorization: Bearer header to ingest events.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
CHURNGUARD_INGEST_SECRET="REPLACE_WITH_RANDOM_SECRET_MIN_32_CHARS"

# ─── Public URL ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

